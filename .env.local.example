# ─── SUPABASE ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server only — never expose client-side

# ─── STRIPE (scaffold — not charging yet) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_VERIFIED_MONTHLY=price_...           # $99/mo — scaffold for future
STRIPE_PRICE_VERIFIED_ANNUAL=price_...            # $990/yr — scaffold for future

# ─── EMAIL (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@rentcheck.com

# ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ─── PUBLIC DATA APIS ────────────────────────────────────────────────────────
NYC_OPEN_DATA_APP_TOKEN=your-token          # data.cityofnewyork.us — free registration
CHICAGO_DATA_APP_TOKEN=your-token           # data.cityofchicago.org — free registration
SF_DATA_APP_TOKEN=your-token                # data.sfgov.org — free registration
BOSTON_DATA_APP_TOKEN=your-token            # data.boston.gov — free registration
COURT_LISTENER_TOKEN=your-token             # courtlistener.com — free account, use v4 API
LSC_API_KEY=your-key                        # Request from civilcourtdata.lsc.gov

# ─── ANALYTICS ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── MONITORING ──────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ─── SECURITY ────────────────────────────────────────────────────────────────
CRON_SECRET=generate-a-long-random-string   # Protects /api/sync/* routes from public access
ADMIN_SECRET=generate-another-long-random-string

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development             # development | staging | production

# ─── INSURANCE AFFILIATE (scaffold — activate later) ─────────────────────────
LEMONADE_AFFILIATE_ID=your-id
LEMONADE_AFFILIATE_BASE_URL=https://www.lemonade.com/renters/affiliate

# ─── SCREENING (Phase 2 — scaffold only) ─────────────────────────────────────
TRANSUNION_API_KEY=your-key
TRANSUNION_API_SECRET=your-secret
TRANSUNION_BASE_URL=https://api.mysmartmove.com

# ─── MAPS (Phase 2) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
